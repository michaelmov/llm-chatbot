# LLM Provider
LLM_PROVIDER=anthropic

# Model Configuration
MODEL_NAME=claude-sonnet-4-5-20250929
MODEL_TEMPERATURE=0.3
MODEL_MAX_TOKENS=4096

# API Keys
# Note: Anthropic API keys are provided per-user via the Settings UI (stored encrypted in DB)
WEATHER_API_KEY=your-weather-api-key-here

# Database
DATABASE_URL=postgresql://chatbot:chatbot_dev@localhost:5432/chatbot

# Authentication (required - never commit this!)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32

# App URL (defaults to http://localhost:3000 for development)
# Set to your production domain in Docker/self-hosted environments
BASE_URL=https://yourdomain.com

# Cookie domain (only needed for production with separate subdomains)
# COOKIE_DOMAIN=.example.com
# COOKIE_SECURE=true
